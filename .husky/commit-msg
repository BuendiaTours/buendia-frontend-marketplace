# Validate conventional commit format
npx --no -- commitlint --edit "$1"

# Verify commit is signed (GPG or SSH)
if ! git verify-commit HEAD 2>/dev/null && [ -z "$GIT_AUTHOR_DATE" ]; then
  # HEAD doesn't exist yet (first commit) or we're mid-commit,
  # so check if gpgsign is configured instead
  SIGN_COMMITS=$(git config --get commit.gpgsign)
  if [ "$SIGN_COMMITS" != "true" ]; then
    echo ""
    echo "ERROR: Commits must be signed."
    echo "Configure signing with: git config --global commit.gpgsign true"
    echo "See: https://docs.github.com/en/authentication/managing-commit-signature-verification"
    echo ""
    exit 1
  fi
fi
