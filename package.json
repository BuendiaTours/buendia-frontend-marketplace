{
	"name": "sveltekit-poc",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"generate:enums": "npx tsx scripts/generate-enums-from-api.ts",
		"storybook": "storybook dev -p 6006 --config-dir .storybook-marketplace",
		"storybook-tunnel": "cloudflared tunnel --url http://localhost:6006",
		"build-storybook": "storybook build --config-dir .storybook-marketplace -o storybook-static-marketplace"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.0.1",
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@inlang/paraglide-js": "^2.9.1",
		"@melt-ui/pp": "^0.3.2",
		"@storybook/addon-a11y": "^10.2.8",
		"@storybook/addon-docs": "^10.2.8",
		"@storybook/addon-svelte-csf": "^5.0.10",
		"@storybook/addon-vitest": "^10.2.8",
		"@storybook/sveltekit": "^10.2.8",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/coverage-v8": "^4.0.18",
		"daisyui": "^5.5.14",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.2.8",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"playwright": "^1.58.2",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.2.8",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"svelte-iconoir": "^0.15.0",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"valibot": "^1.2.0",
		"vite": "^7.2.6",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@bytemd/plugin-gfm": "^1.21.0",
		"@internationalized/date": "^3.10.1",
		"@melt-ui/svelte": "^0.86.6",
		"bytemd": "^1.21.0",
		"photoswipe": "^5.4.4",
		"sveltekit-superforms": "2.18.1",
		"swiper": "^12.0.3",
		"theme-change": "^2.5.0",
		"uuid": "^13.0.0",
		"zod": "3.23.8"
	},
	"overrides": {
		"zod": "3.23.8",
		"zod-to-json-schema": "3.23.2"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.{json,css,md,html,yaml,yml}": [
			"prettier --write"
		]
	}
}
