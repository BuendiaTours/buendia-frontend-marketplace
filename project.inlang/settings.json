{
	"$schema": "https://inlang.com/schema/project-settings",
	"baseLocale": "es",
	"locales": ["es"],
	"modules": [
		"https://cdn.jsdelivr.net/npm/@inlang/plugin-message-format@4/dist/index.js",
		"https://cdn.jsdelivr.net/npm/@inlang/plugin-m-function-matcher@2/dist/index.js"
	],
	"plugin.inlang.messageFormat": {
		"pathPattern": [
			"./messages/{locale}/common.json",
			"./messages/{locale}/backoffice.json",
			"./messages/{locale}/activities.json",
			"./messages/{locale}/enums.json",
			"./messages/{locale}/users.json",
			"./messages/{locale}/locations.json",
			"./messages/{locale}/geoJson.json",
			"./messages/{locale}/attractions.json",
			"./messages/{locale}/categories.json",
			"./messages/{locale}/suppliers.json"
		]
	}
}
